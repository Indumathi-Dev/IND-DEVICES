# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
PORT=8090

# DEVELOPMENT → uses mock handlers from apps/*/mocks/
# PRODUCTION  → uses real controllers from apps/*/controller/
MODE=DEVELOPMENT

# Real backend base URL (only used when MODE=PRODUCTION)
API_BASE_URL=http://localhost:7000
